# Gemini API Key
GOOGLE_API_KEY=your_gemini_api_key_here

# Google Drive Service Account Credentials (JSON string or path to file)
# If using a file, set the path here:
GOOGLE_APPLICATION_CREDENTIALS=data/service-account.json

# If using a JSON string (better for Railway/Render), paste the content here:
# SERVICE_ACCOUNT_JSON='{"type": "service_account", ...}'

# Target Folder ID (The folder you shared with the service account)
DRIVE_FOLDER_ID=your_shared_folder_id_here
